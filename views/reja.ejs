<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>REJA</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      crossorigin="anonymous"
    />
  </head>

  <body style="background-color: #b8bbd1">
    <div class="container">
      <h1 class="display-4 text-center py-1">REJA VA MQSADLAR</h1>

      <div class="jumbotron p-3 shadow-sm">
        <form id="create-form" action="/create-item" method="POST">
          <div class="d-flex align-items-center">
            <input
              type="text"
              name="item"
              id="create-field"
              autofocus
              autocomplete="off"
              class="form-control mr-3"
              style="flex: 1"
            />
            <button class="btn btn-primary" style="border-radius: 20px">
              Yangi Reja Qoshish
            </button>
          </div>
        </form>
      </div>

      <button id="clean-all" class="btn btn-danger" style="border-radius: 20px">
        Hamma Rejalarni ochirish
      </button>
    </div>

    <div></div>
  </body>
</html>
