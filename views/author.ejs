<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <title>Portfolio</title>
</head>

<body>
    <div class="frame">
        <div class="main_frame">
            <div class="left_frame">

                <div class="left_1">
                    <div class="left_1_1">
                        <img src="images/profile.png" width="156px"  height="142px" alt="">
                    </div>
                    <div class="left_1_2"><%=user.name%></div>
                    <div class="left_1_3"><%=user.profession%></div>
                    <div class="left-icons">
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/dribbble.svg" class="icon-1">
                            </div>
                        </a>
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/facebook.svg" class="icon-1">
                            </div>
                        </a>
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/instagram.svg" class="icon-1">
                            </div>
                        </a>
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/linkedin.svg" class="icon-1">
                            </div>
                        </a>
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/twitter.svg" class="icon-1">
                            </div>
                        </a>
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/youtube.svg" class="icon-1">
                            </div>
                        </a>
                    </div>
                </div>

                <div class="marginer"></div>

                <div class="left_2">
                    <div class="left_2_1">
                        <div class="info">Age:</div>
                        <div><%=user.age%></div>
                    </div>
                    <div class="left_2_1">
                        <div class="info">Residence:</div>
                        <div><%=user.residence%></div>
                    </div>
                    <div class="left_2_1">
                        <div class="info">Freelance:</div>
                        <div style="color: rgb(60, 156, 60);">Available</div>
                    </div>
                    <div class="left_2_1">
                        <div class="info">Address:</div>
                        <div><%=user.address%></div>
                    </div>
                </div>

                <div class="marginer"></div>

                <div class="left_3">
                    <div style="margin-bottom: 15px;">Languages</div>
                    <div class="left_3_lan">
                        <div><%=user.languages[0]%></div>
                        <div>100%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 100%;"></div></div>
                    <div class="left_3_lan">
                        <div><%=user.languages[1]%></div>
                        <div>80%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 80%;"></div></div>
                    <div class="left_3_lan">
                        <div><%=user.languages[2]%></div>
                        <div>60%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 60%;"></div></div>
                </div>

                <div class="marginer"></div>

                <div class="left_4">
                    <div style="margin-bottom: 15px;">Skills</div>
                    <div class="left_4_skill">
                        <div><%=user.skills[0]%></div>
                        <div>90%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 90%;"></div></div>
                    <div class="left_4_skill">
                        <div><%=user.skills[1]%></div>
                        <div>85%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 85%;"></div></div>
                    <div class="left_4_skill">
                        <div><%=user.skills[2]%></div>
                        <div>80%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 80%;"></div></div>
                    <div class="left_4_skill">
                        <div><%=user.skills[3]%></div>
                        <div>75%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 75%;"></div></div>
                    <div class="left_4_skill">
                        <div><%=user.skills[4]%></div>
                        <div>85%</div>
                    </div>
                    <div class="progress-bg"><div class="progress-fill" style="width: 85%;"></div></div>
                </div>

                <div class="marginer"></div>

                <div class="left_5"></div>

                <div class="marginer"></div>

            </div>

            <div class="midd_frame"></div>
            <div class="right_frame"></div>
        </div>
    </div>
</body>

</html>
